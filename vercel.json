{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/trilha-admin/dist",
  "rewrites": [
    { "source": "/institution/", "destination": "/api/institution" },
    { "source": "/institution", "destination": "/api/institution" },
    { "source": "/institution/simple", "destination": "/api/institution?simple=1" },
    {
      "source": "/institution/:id([A-Za-z0-9_-]+)",
      "destination": "/api/institution?id=:id"
    },
    {
      "source": "/institution/:id([A-Za-z0-9_-]+)/",
      "destination": "/api/institution?id=:id"
    },
    { "source": "/student/", "destination": "/api/student" },
    { "source": "/student", "destination": "/api/student" },
    { "source": "/student/simple", "destination": "/api/student?simple=1" },
    {
      "source": "/student/:phone([0-9]+)",
      "destination": "/api/student?phone_number=:phone"
    },
    {
      "source": "/student/:id([A-Za-z0-9_-]+)",
      "destination": "/api/student?id=:id"
    },
    {
      "source": "/student/:id([A-Za-z0-9_-]+)/",
      "destination": "/api/student?id=:id"
    },
    { "source": "/students/", "destination": "/api/student" },
    { "source": "/students", "destination": "/api/student" },
    { "source": "/students/simple", "destination": "/api/student?simple=1" },
    {
      "source": "/students/:phone([0-9]+)",
      "destination": "/api/student?phone_number=:phone"
    },
    {
      "source": "/students/:id([A-Za-z0-9_-]+)",
      "destination": "/api/student?id=:id"
    },
    {
      "source": "/students/:id([A-Za-z0-9_-]+)/",
      "destination": "/api/student?id=:id"
    },
    { "source": "/trails/", "destination": "/api/trails" },
    { "source": "/trails", "destination": "/api/trails" },
    { "source": "/trails/simple", "destination": "/api/trails?simple=1" },
    {
      "source": "/trails/:id([A-Za-z0-9_-]+)",
      "destination": "/api/trails?id=:id"
    },
    {
      "source": "/trails/:id([A-Za-z0-9_-]+)/",
      "destination": "/api/trails?id=:id"
    },
    { "source": "/trail_stages/", "destination": "/api/trail_stages" },
    { "source": "/trail_stages", "destination": "/api/trail_stages" },
    { "source": "/trail_stages/simple", "destination": "/api/trail_stages?simple=1" },
    {
      "source": "/trail_stages/:id([A-Za-z0-9_-]+)",
      "destination": "/api/trail_stages?id=:id"
    },
    {
      "source": "/trail_stages/:id([A-Za-z0-9_-]+)/",
      "destination": "/api/trail_stages?id=:id"
    },
    {
      "source": "/trail_stage_questions/",
      "destination": "/api/trail_stage_questions"
    },
    {
      "source": "/trail_stage_questions",
      "destination": "/api/trail_stage_questions"
    },
    {
      "source": "/trail_stage_questions/simple",
      "destination": "/api/trail_stage_questions?simple=1"
    },
    {
      "source": "/trail_stage_questions/:id([A-Za-z0-9_.-]+)",
      "destination": "/api/trail_stage_questions?id=:id"
    },
    {
      "source": "/trail_stage_questions/:id([A-Za-z0-9_.-]+)/",
      "destination": "/api/trail_stage_questions?id=:id"
    },
    { "source": "/student_trails/", "destination": "/api/student_trails" },
    { "source": "/student_trails", "destination": "/api/student_trails" },
    { "source": "/conversation_logs/", "destination": "/api/conversation_logs" },
    { "source": "/conversation_logs", "destination": "/api/conversation_logs" },
    {
      "source": "/conversation_logs/:id([A-Za-z0-9_-]+)",
      "destination": "/api/conversation_logs?id=:id"
    },
    {
      "source": "/conversation_logs/:id([A-Za-z0-9_-]+)/",
      "destination": "/api/conversation_logs?id=:id"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
