// Arquivo: firestore.rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /institutions/{institutionId} {
      allow read, write: if true;
    }

    match /students/{studentId} {
      allow read, write: if true;
    }

    match /trails/{trailId} {
      allow read: if true;
      allow create: if true;
      // Não permite re-vincular trilha para outra instituição via client SDK.
      allow update: if request.resource.data.institution_id == resource.data.institution_id;
      // Exclusão de trilhas deve ocorrer no backend com cascade seguro.
      allow delete: if false;
    }

    match /trail_stages/{trailStageId} {
      allow read, write: if true;
    }

    match /trail_stage_questions/{questionId} {
      allow read, write: if true;
    }

    match /student_trails/{studentTrailId} {
      allow read, write: if true;
    }

    match /conversation_logs/{logId} {
      allow read, write: if true;
    }

    match /exercise_attempts/{attemptId} {
      allow read, write: if true;
    }

    // Permissões por login (painel /admin)
    match /admin_users/{userId} {
      allow read, write: if true;
    }

    // Contadores para IDs sequenciais
    match /counters/institutions {
      allow read, write: if true;
    }
    match /counters/students {
      allow read, write: if true;
    }
    match /counters/trails {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
